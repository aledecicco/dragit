{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "Dragit",
  "version": "1.7.2",
  "identifier": "com.dragit",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Dragit",
        "maximized": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDhBRTQ2Qjg0QjVENERBODUKUldTRjJ0UzFoR3ZraXZERlFNeHAwRXg4WnZQaWltZnNheWY5d2RNcitTQWtMek1uWmhTRnNSMm4K",
      "endpoints": [
        "https://github.com/aledecicco/dragit/releases/latest/download/latest.json"
      ]
    }
  }
}
