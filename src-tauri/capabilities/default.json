{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "dialog:allow-open",
    "clipboard-manager:allow-write-text",
    "store:default",
    "process:default",
    "shell:allow-spawn",
    "shell:allow-execute",
    "shell:allow-kill",
    {
      "identifier": "http:default",
      "allow": [{ "url": "https://api.github.com/search/users"}]
    }
  ]
}
